---
import BaseLayout from '../layouts/BaseLayout.astro';
import { REPO_URL, SSR_INSTALL_ARIA_LABEL } from '../scripts/install-target';
const title = 'Dissatisfied — Focus without the noise';
const description =
  'A browser extension that hides clutter on YouTube, Twitter/X, and Excalidraw so you can focus on what matters.';
---

<BaseLayout title={title} description={description} currentPath="/">
  <div class="home-landing">
    <div class="home-hero">
      <h1 class="hero-animate headline focus-title-trigger">
        Dissatisfied
      </h1>
      <p class="lead hero-animate page-fade-chrome">
        Focus without the noise. Strip the chrome, keep the content—on YouTube, Twitter/X, and Excalidraw.
      </p>
      <div class="hero-actions hero-animate page-fade-chrome">
        <a
          id="hero-extension-cta"
          class="btn btn-primary btn-extension-cta"
          href={REPO_URL}
          target="_blank"
          rel="noreferrer"
          aria-label={SSR_INSTALL_ARIA_LABEL}
        >
          <span class="btn-extension-cta-icon-wrap">
            <img data-hero-cta-icon src="/github-mark.svg" alt="GitHub" width="18" height="18" decoding="async" />
          </span>
          <span data-hero-cta-text>Build from source on GitHub</span>
        </a>
        <a class="btn btn-ghost" href="/about">About the project</a>
      </div>
    </div>

    <button
      type="button"
      class="focus-demo-trigger btn btn-ghost page-fade-chrome focus-hint--touch"
      aria-pressed="false"
      aria-label="Toggle focus mode preview"
    >
      Tap to preview focus mode
    </button>

    <section class="showcase reveal-section" aria-labelledby="preview-heading">
      <p id="preview-heading" class="showcase-label page-fade-chrome">Preview</p>
      <div class="shots focus-shots">
        <figure class="shot">
          <img
            src="/screenshot-focus-mode-1.png"
            alt="YouTube with Dissatisfied focus mode: cleaner layout and theater-friendly view"
            width="800"
            height="450"
            loading="eager"
            decoding="async"
          />
        </figure>
        <figure class="shot">
          <img
            src="/screenshot-focus-mode-2.png"
            alt="Twitter or X with Dissatisfied: timeline centered, side panels hidden"
            width="800"
            height="450"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>
  </div>

  <section class="features page-fade-chrome" aria-labelledby="features-heading">
    <h2 id="features-heading" class="visually-hidden">Features</h2>
    <article class="feature">
      <h3>Sites you use</h3>
      <p>
        YouTube, Twitter/X, and excalidraw.com—toggle focus from the page, the toolbar popup, or full options.
      </p>
    </article>
    <article class="feature">
      <h3>Shortcuts</h3>
      <p>
        On-page: <kbd class="kbd-inline">`</kbd> on YouTube; <kbd class="kbd-inline">Ctrl/Cmd+B</kbd> or
        <kbd class="kbd-inline">Option+Shift+X</kbd> on Twitter/X; <kbd class="kbd-inline">Ctrl/Cmd+B</kbd> on
        Excalidraw. Browser commands (customizable): Ctrl/Cmd+Shift+Y and Ctrl/Cmd+Shift+X.
      </p>
    </article>
    <article class="feature">
      <h3>Your data</h3>
      <p>
        Settings live in extension storage on your device. Nothing is sent to us—see <a href="/privacy">Privacy</a>.
      </p>
    </article>
  </section>

  <script>
    import '../scripts/hero-extension-cta.ts';
  </script>
</BaseLayout>
